<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no"
    />
    <title>APE Milano</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>

  <body>
    <header>
      <div class="logo">
        <img src="/images/logo.png" alt="APE Milano" />
      </div>
      <div class="title">
        <span class="strong"> ATTESTATO PRESTAZIONE ENERGETICA </span>
        <span class="dash"> - </span>
        <span class="light"> MILANO E HINTERLAND </span>
      </div>
      <div class="separator"></div>
    </header>
    <main>
      <section class="card">
        <h2>COMUNE IMMOBILE</h2>
        <label>COMUNE</label>
        <input type="text" id="comune" />
        <label>INDIRIZZO</label>
        <input type="text" id="indirizzo" />
        <label>CAP</label>
        <input type="number" inputmode="numeric" pattern="[0-9]*" id="cap" />
        <label>SCALA</label>
        <input type="text" id="scala" />
        <label>INTERNO</label>
        <input type="text" id="interno" />
      </section>

      <section class="card">
        <h2>DATI IMMOBILE</h2>
        <label>TIPOLOGIA</label>
        <select>
          <option>APPARTAMENTO</option>
          <option>VILLA</option>
          <option>UFFICIO</option>
        </select>
        <label>SUPERFICIE (mq)</label>
        <input
          type="number"
          inputmode="numeric"
          pattern="[0-9]*"
          id="superficie"
        />
        <div class="field-group">
          <label>ANNO COSTRUZIONE</label>
          <input type="text" inputmode="numeric" pattern="[0-9]*" id="anno" />
          <label class="check">
            <input type="checkbox" id="anno_unknown" />
            Non conosco l'anno di costruzione
          </label>
        </div>
        <label>RISCALDAMENTO</label>
        <select>
          <option>CENTRALIZZATO</option>
          <option>AUTONOMO</option>
        </select>
        <label>CAPPOTTO TERMICO</label>
        <select>
          <option>NO</option>
          <option>SÌ</option>
          <option>NON SO</option>
        </select>
      </section>

      <section class="card">
        <h2>SOPRALLUOGO</h2>
        <label>DATA</label>
        <input type="date" id="data" />
        <label>ORARIO</label>
        <input type="time" id="orario" />
        <p class="note">
          Il sopralluogo in loco è obbligatorio ai sensi del D.M. 26 giugno
          2015. La sua assenza comporta la non validità dell’APE e sanzioni
          amministrative per il propeitario dell'immobile. Diffida dagli enti
          che rilasciano l’attestato senza sopralluogo.
        </p>
      </section>
    </main>

    <footer>
      <button>CALCOLA PREVENTIVO</button>
    </footer>

    <script>
      // Data validation numerica
      document.querySelectorAll("#cap, #superficie, #anno").forEach((input) => {
        input.addEventListener("input", () => {
          input.value = input.value.replace(/[^0-9]/g, "");
        });
      });

      // Logica checkbox anno di costruzione
      const annoInput = document.getElementById("anno");
      const checkbox = document.getElementById("anno_unknown");
      checkbox.addEventListener("change", () => {
        if (checkbox.checked) {
          annoInput.value = "?";
          annoInput.disabled = true;
        } else {
          annoInput.value = "";
          annoInput.disabled = false;
        }
      });
    </script>
  </body>
</html>
