<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>APE Milano</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>
<header>
    <div class="logo">
        <img src="/images/logo.png" alt="APE Milano">
    </div>
    <div class="title">
        <span class="strong">ATTESTATO PRESTAZIONE ENERGETICA</span>
        <span class="light"> - MILANO E HINTERLAND</span>
    </div>
</header>
<div class="separator"></div>
<main>
    <section class="card">
        <h2>COMUNE IMMOBILE</h2>
        <label>COMUNE</label>
        <input type="text">
        <label>INDIRIZZO</label>
        <input type="text">
        <div class="row">
            <div>
                <label>CAP</label>
                <input type="text">
            </div>
            <div>
                <label>SCALA</label>
                <input type="text">
            </div>
            <div>
                <label>INTERNO</label>
                <input type="text">
            </div>
        </div>
    </section>

    <section class="card">
        <h2>DATI IMMOBILE</h2>
        <label>TIPOLOGIA</label>
        <select>
            <option>APPARTAMENTO</option>
            <option>VILLA</option>
            <option>UFFICIO</option>
        </select>
        <label>SUPERFICIE (mq)</label>
        <input type="number">
        <label>ANNO COSTRUZIONE</label>
        <input type="number">
        <label class="check">
            <input type="checkbox">
            Non sono a conoscenza dell'anno di costruzione
        </label>
        <label>RISCALDAMENTO</label>
        <select>
            <option>CENTRALIZZATO</option>
            <option>AUTONOMO</option>
        </select>
        <label class="check">
            <input type="checkbox">
            CAPPOTTO TERMICO
        </label>
    </section>

    <section class="card">
        <h2>SOPRALLUOGO</h2>
        <label>DATA</label>
        <input type="date">
        <label>ORARIO</label>
        <input type="time">
    </section>
</main>

<footer>
    <button>
        CALCOLA PREVENTIVO
    </button>
</footer>
</body>
</html>