<!DOCTYPE html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no"
    />
    <title>APE Milano</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>

  <body>
    <header>
      <div class="logo">
        <img src="/images/logo.png" alt="APE Milano" />
      </div>
      <div class="title">
        <span class="strong"> ATTESTATO PRESTAZIONE ENERGETICA </span>
        <span class="dash"> - </span>
        <span class="light"> MILANO E HINTERLAND </span>
      </div>
    </header>

    <div class="separator"></div>

    <div class="top-banner">
      <div class="banner-item">
        <img src="/images/icon-price.png" alt="" class="banner-icon" />
        <div class="banner-text">
          <span class="banner-title">APE a partire da 119€</span>
          <span class="banner-subtitle">IVA inclusa</span>
        </div>
      </div>
      <div class="banner-item">
        <img src="/images/icon-calendar.png" alt="" class="banner-icon" />
        <div class="banner-text">
          <span class="banner-title">Sopralluoghi flessibili</span>
          <span class="banner-subtitle"
            >Lun-Ven 18:00–20:00 • Sabato tutto il giorno</span
          >
        </div>
      </div>
      <div class="banner-item">
        <img src="/images/icon-speed.png" alt="" class="banner-icon" />
        <div class="banner-text">
          <span class="banner-title">Certificato in 48h</span>
          <span class="banner-subtitle">Dal momento del sopralluogo</span>
        </div>
      </div>
      <div class="banner-item">
        <img src="/images/icon-snail.png" alt="" class="banner-icon" />
        <div class="banner-text">
          <span class="banner-title">Nessuna registrazione</span>
          <span class="banner-subtitle"
            >Compila il form e consulta il preventivo</span
          >
        </div>
      </div>
    </div>

    <div class="separator"></div>

    <main>
      <section class="card">
        <h2>COMUNE IMMOBILE</h2>
        <label>COMUNE</label>
        <input type="text" id="comune" />
        <label>INDIRIZZO</label>
        <input type="text" id="indirizzo" />
        <label>CAP</label>
        <input type="number" inputmode="numeric" pattern="[0-9]*" id="cap" />
        <label>SCALA</label>
        <input type="text" id="scala" />
        <label>INTERNO</label>
        <input type="text" id="interno" />
      </section>

      <section class="card">
        <h2>DATI IMMOBILE</h2>
        <label>TIPOLOGIA</label>
        <select required>
          <option value="" selected disabled hidden>
            Seleziona un'opzione
          </option>
          <option>APPARTAMENTO</option>
          <option>VILLA</option>
          <option>UFFICIO</option>
          <option>ALTRO</option>
        </select>
        <label>SUPERFICIE (mq)</label>
        <input
          type="number"
          inputmode="numeric"
          pattern="[0-9]*"
          id="superficie"
        />
        <div class="field-group">
          <label>ANNO COSTRUZIONE</label>
          <input type="text" inputmode="numeric" pattern="[0-9]*" id="anno" />
          <label class="check">
            <input type="checkbox" id="anno_unknown" />
            Non conosco l'anno di costruzione
          </label>
        </div>
        <label>RISCALDAMENTO</label>
        <select required>
          <option value="" selected disabled hidden>
            Seleziona un'opzione
          </option>
          <option>CENTRALIZZATO</option>
          <option>AUTONOMO</option>
        </select>
        <label>CAPPOTTO TERMICO</label>
        <select required>
          <option value="" selected disabled hidden>
            Seleziona un'opzione
          </option>
          <option>NO</option>
          <option>SÌ</option>
          <option>NON SO</option>
        </select>
      </section>

      <section class="card">
        <h2>SOPRALLUOGO</h2>
        <label>DATA</label>
        <select id="data" required>
          <option value="" selected disabled hidden>Seleziona una data</option>
        </select>
        <label>ORARIO</label>
        <select id="orario" required>
          <option value="" selected disabled hidden>Seleziona un orario</option>
          <option>18:00</option>
          <option>18:30</option>
          <option>19:00</option>
          <option>19:30</option>
          <option>20:00</option>
        </select>
        <p class="note">
          Il sopralluogo in loco è obbligatorio ai sensi del D.M. 26 giugno
          2015. La sua assenza comporta la non validità dell’APE e sanzioni
          amministrative per il propeitario dell'immobile. Diffida dagli enti
          che rilasciano l’attestato senza sopralluogo.
        </p>
      </section>
    </main>

    <footer>
      <button>CALCOLA PREVENTIVO</button>
    </footer>

    <script>
      // Data validation numerica
      document.querySelectorAll("#cap, #superficie, #anno").forEach((input) => {
        input.addEventListener("input", () => {
          input.value = input.value.replace(/[^0-9]/g, "");
        });
      });

      // Logica checkbox anno di costruzione
      const annoInput = document.getElementById("anno");
      const checkbox = document.getElementById("anno_unknown");
      checkbox.addEventListener("change", () => {
        if (checkbox.checked) {
          annoInput.value = "?";
          annoInput.disabled = true;
        } else {
          annoInput.value = "";
          annoInput.disabled = false;
        }
      });

      // Logica blocco orario prima di selezione data
      const dataSelect = document.getElementById("data");
      const orarioSelect = document.getElementById("orario");
      orarioSelect.disabled = true;
      dataSelect.addEventListener("change", () => {
        if (!dataSelect.value) {
          orarioSelect.disabled = true;
        } else {
          orarioSelect.disabled = false;
        }
      });

      // Logica generazione dinamica fasce orarie
      function generaOrari(isSabato) {
        const orari = [];
        if (isSabato) {
          for (let h = 9; h <= 12; h++) {
            orari.push(`${String(h).padStart(2, "0")}:00`);
            if (h !== 12) orari.push(`${String(h).padStart(2, "0")}:30`);
          }
          for (let h = 15; h <= 18; h++) {
            orari.push(`${String(h).padStart(2, "0")}:00`);
            if (h !== 18) orari.push(`${String(h).padStart(2, "0")}:30`);
          }
        } else {
          for (let h = 18; h <= 20; h++) {
            orari.push(`${String(h).padStart(2, "0")}:00`);
            if (h !== 20) orari.push(`${String(h).padStart(2, "0")}:30`);
          }
        }
        return orari;
      }
      dataSelect.addEventListener("change", () => {
        const d = new Date(dataSelect.value);
        const isSabato = d.getDay() === 6;
        const orari = generaOrari(isSabato);
        orarioSelect.innerHTML = `
          <option value="" selected disabled hidden>
            Seleziona un orario
          </option>
        `;
        orari.forEach((o) => {
          const opt = document.createElement("option");
          opt.value = o;
          opt.textContent = o;
          orarioSelect.appendChild(opt);
        });
        orarioSelect.disabled = false;
      });

      // Logica selezione date
      for (let i = 1; i <= 14; i++) {
        const d = new Date();
        d.setDate(d.getDate() + i);
        // salta la domenica
        if (d.getDay() === 0) continue;
        const value = d.toISOString().slice(0, 10);
        const option = document.createElement("option");
        option.value = value;
        const testo = d.toLocaleDateString("it-IT", {
          weekday: "long",
          day: "numeric",
          month: "long",
        });
        option.textContent = testo.charAt(0).toUpperCase() + testo.slice(1);
        dataSelect.appendChild(option);
      }
    </script>
  </body>
</html>
